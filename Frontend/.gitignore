# ── Environment & secrets ─────────────────────────────────────
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Next.js build output ──────────────────────────────────────
.next/
out/
build/
dist/

# ── Next.js cache ─────────────────────────────────────────────
.next/cache/

# ── Tailwind generated ────────────────────────────────────────
# tailwind.config.js and postcss.config.js should be committed
# Only ignore generated output if you have a separate build step
# (most setups don't generate separate files — nothing to ignore)

# ── Logs ──────────────────────────────────────────────────────
logs/*
!logs/.gitkeep
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Testing ───────────────────────────────────────────────────
coverage/
.jest-cache/

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misc ──────────────────────────────────────────────────────
*.pem
.vercel
.turbo